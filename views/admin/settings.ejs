<%- include('layout-open') %>
<div class="admin-page">
  <div class="page-header-bar"><h1>⚙️ 系统设置</h1></div>
  <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success">✅ <%= success %></div><% } %>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error">❌ <%= error %></div><% } %>

  <form method="POST" action="/admin/settings">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
    <div class="admin-panel">
      <h2>🌐 网站设置</h2>
      <div class="settings-form-grid">
        <div class="form-group"><label>网站标题</label><input type="text" name="site_title" value="<%= config.site_title || '' %>"></div>
        <div class="form-group settings-field-wide"><label>网站描述</label><textarea class="settings-textarea" name="site_description" rows="3"><%= config.site_description || '' %></textarea></div>
        <div class="form-group"><label>🎯 网站主题</label><input type="text" name="site_theme" value="<%= config.site_theme || '' %>" placeholder="如: 人工智能与前端开发"></div>
        <div class="form-group settings-field-wide"><label>📈 发展方向</label><textarea class="settings-textarea" name="site_direction" rows="3" placeholder="如: 聚焦最新 AI 工具评测"><%= config.site_direction || '' %></textarea></div>
        <div class="form-group settings-field-wide"><label>网站地址</label><input type="url" name="site_url" value="<%= config.site_url || 'http://localhost:3000' %>"></div>
        <div class="form-group"><label>语言</label><select name="site_language"><option value="zh-CN" <%= config.site_language === 'zh-CN' ? 'selected' : '' %>>中文</option><option value="en" <%= config.site_language === 'en' ? 'selected' : '' %>>英文</option></select></div>
      </div>
    </div>

    <div class="admin-panel" style="margin-top:1.5rem">
      <h2>🔍 Tavily 搜索引擎</h2>
      <p class="text-muted" style="margin-bottom:1rem">Tavily 是专业搜索引擎 API，配置后搜索结果更精准。不配置也不影响正常运行——系统默认使用 DuckDuckGo + Bing 等免费搜索引擎。免费额度：每月 1000 次搜索。<a href="https://tavily.com" target="_blank">获取 Key →</a></p>
      <%
        var tavilyKeyText = config.tavily_api_key || '';
        var tavilyKeyCount = tavilyKeyText.split(/[\n,]+/).map(function(k){ return k.trim(); }).filter(Boolean).length;
      %>
      <div class="tavily-key-card">
        <div>
          <div class="tavily-key-count"><strong id="tavilyKeyCount"><%= tavilyKeyCount %></strong> 个 Key</div>
          <p class="text-muted">系统会按轮询方式自动负载均衡，单个 Key 失败时会尝试下一个。</p>
        </div>
        <div class="tavily-key-actions">
          <button type="button" class="btn btn-outline" onclick="openTavilyKeysModal()">管理 Key</button>
          <button
            type="button"
            class="btn btn-primary"
            id="tavilyValidateBtn"
            data-test-url="/admin/settings/tavily/test"
            data-csrf-token="<%= csrfToken %>"
          >一键验证</button>
        </div>
      </div>
      <div id="tavilyTestResult" class="tavily-test-result" hidden></div>
      <div id="tavilyKeysModal" class="admin-modal" hidden>
        <div class="admin-modal-backdrop" onclick="closeTavilyKeysModal()"></div>
        <div class="admin-modal-panel" role="dialog" aria-modal="true" aria-labelledby="tavilyKeysTitle">
          <div class="admin-modal-header">
            <h3 id="tavilyKeysTitle">Tavily API Keys</h3>
            <button type="button" class="modal-close" onclick="closeTavilyKeysModal()">×</button>
          </div>
          <div class="form-group">
            <label>一行一个 Key</label>
            <textarea class="settings-textarea tavily-key-textarea" id="tavilyKeysInput" name="tavily_api_key" rows="9" placeholder="tvly-xxx&#10;tvly-yyy"><%= tavilyKeyText %></textarea>
            <small>可直接粘贴多行；保存设置后生效。</small>
          </div>
          <div class="form-actions">
            <button type="button" class="btn btn-primary" onclick="applyTavilyKeysModal()">应用到表单</button>
            <button type="button" class="btn btn-outline" onclick="closeTavilyKeysModal()">取消</button>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-panel" style="margin-top:1.5rem">
      <h2>MoA 模型协作</h2>
      <p class="text-muted" style="margin-bottom:1rem">开启后，文章生成和去 AI 味重写会尝试多个模型并行产出候选稿，再由聚合模型综合为最终结果。MoA 失败时会自动回退到现有单模型流程；关闭后保持当前逻辑不变。</p>
      <input type="hidden" name="moa_enabled" value="0">
      <label class="toggle-row" style="display:flex;align-items:center;gap:0.75rem">
        <input type="checkbox" name="moa_enabled" value="1" <%= config.moa_enabled === '1' ? 'checked' : '' %>>
        <span>启用 MoA 多模型协作模式</span>
      </label>
    </div>

    <div class="form-actions"><button type="submit" class="btn btn-primary btn-lg">💾 保存设置</button></div>
  </form>

  <!-- 工作模式独立表单 -->
  <form method="POST" action="/admin/work-mode" style="margin-top:1.5rem" id="workModeForm">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
    <div class="admin-panel">
      <h2>⚡ 工作模式</h2>
      <%
        var currentMode = config.work_mode || 'smart';
        var currentLevel = parseInt(config.rage_level) || 3;
      %>
      <div class="mode-switch">
        <div class="mode-card <%= currentMode === 'smart' ? 'mode-active' : '' %>" onclick="selectMode('smart')">
          <div class="mode-icon">🧠</div>
          <div class="mode-name">智能模式</div>
          <div class="mode-desc">按定时任务调度，每天固定时间工作，省资源</div>
        </div>
        <div class="mode-card <%= currentMode === 'rage' ? 'mode-active' : '' %>" onclick="selectMode('rage')">
          <div class="mode-icon">🔥</div>
          <div class="mode-name">狂暴模式</div>
          <div class="mode-desc">AI 无休止持续工作，多线程并发生成内容</div>
        </div>
      </div>
      <input type="hidden" name="work_mode" id="work_mode" value="<%= currentMode %>">

      <div id="rage-settings" style="margin-top:1.5rem; <%= currentMode === 'rage' ? '' : 'display:none' %>">
        <label style="font-weight:600;margin-bottom:0.75rem;display:block">🔥 狂暴档位：<span id="level-display" style="color:var(--primary)"><%= currentLevel %></span> / 10</label>
        <input type="range" name="rage_level" id="rage_level" min="1" max="10" value="<%= currentLevel %>" oninput="document.getElementById('level-display').textContent=this.value" style="width:100%;accent-color:var(--primary)">
        <div class="mode-level-desc" id="level-desc">
          <% if (currentLevel <= 2) { %>
            🟢 低速 — 1-2 个编辑并发，适合低频更新
          <% } else if (currentLevel <= 5) { %>
            🟡 中速 — 3-5 个编辑并发，持续高频产出
          <% } else if (currentLevel <= 8) { %>
            🟠 高速 — 6-8 个编辑并发，大量内容爆发
          <% } else { %>
            🔴 极速 — 9-10 个编辑并发，全速内容轰炸
          <% } %>
        </div>
        <p class="text-muted" style="margin-top:0.5rem">档位越高，并发越多，AI 调用越频繁。建议根据 API 额度选择。</p>
      </div>

      <div class="form-actions" style="margin-top:1rem">
        <button type="submit" class="btn btn-primary btn-lg">⚡ 应用模式</button>
        <% if (currentMode === 'rage') { %>
          <button type="button" class="btn btn-outline btn-lg" onclick="switchToSmart()">🧠 切回智能模式</button>
        <% } %>
      </div>
    </div>
  </form>

  <form method="POST" action="/admin/change-password" style="margin-top:1.5rem">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
    <div class="admin-panel">
      <h2>🔒 修改密码</h2>
      <div class="form-grid">
        <div class="form-group"><label>原密码</label><input type="password" name="old_password" required></div>
        <div class="form-group"><label>新密码</label><input type="password" name="new_password" required></div>
      </div>
      <div class="form-actions"><button type="submit" class="btn btn-outline">🔒 修改密码</button></div>
    </div>
  </form>
</div>
<%- include('layout-close') %>
<script>
function selectMode(mode) {
  document.getElementById('work_mode').value = mode;
  document.querySelectorAll('.mode-card').forEach(function(c) { c.classList.remove('mode-active'); });
  event.currentTarget.classList.add('mode-active');
  document.getElementById('rage-settings').style.display = mode === 'rage' ? '' : 'none';
}
function switchToSmart() {
  if (!confirm('切换回智能模式将停止狂暴循环，确认？')) return;
  document.getElementById('work_mode').value = 'smart';
  document.getElementById('rage_level').value = '3';
  document.getElementById('workModeForm').submit();
}
function tavilyKeys() {
  var input = document.getElementById('tavilyKeysInput');
  if (!input) return [];
  var seen = {};
  return input.value.split(/[\n,]+/).map(function(k) { return k.trim(); }).filter(function(k) {
    if (!k || seen[k]) return false;
    seen[k] = true;
    return true;
  });
}
function refreshTavilyKeyCount() {
  var count = document.getElementById('tavilyKeyCount');
  if (count) count.textContent = tavilyKeys().length;
}
function openTavilyKeysModal() {
  var modal = document.getElementById('tavilyKeysModal');
  if (modal) modal.hidden = false;
  var input = document.getElementById('tavilyKeysInput');
  if (input) input.focus();
}
function closeTavilyKeysModal() {
  var modal = document.getElementById('tavilyKeysModal');
  if (modal) modal.hidden = true;
}
function applyTavilyKeysModal() {
  var input = document.getElementById('tavilyKeysInput');
  if (input) input.value = tavilyKeys().join('\n');
  refreshTavilyKeyCount();
  closeTavilyKeysModal();
}
function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, function(ch) {
    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
  });
}
document.getElementById('tavilyKeysInput')?.addEventListener('input', refreshTavilyKeyCount);
document.getElementById('tavilyValidateBtn')?.addEventListener('click', async function() {
  applyTavilyKeysModal();
  var resultBox = document.getElementById('tavilyTestResult');
  var button = this;
  if (!resultBox) return;
  resultBox.hidden = false;
  resultBox.className = 'tavily-test-result';
  resultBox.textContent = '正在验证...';
  button.disabled = true;
  try {
    var body = new URLSearchParams();
    body.set('csrf_token', button.dataset.csrfToken || '');
    body.set('tavily_api_key', document.getElementById('tavilyKeysInput')?.value || '');
    var response = await fetch(button.dataset.testUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': button.dataset.csrfToken || '' },
      body: body.toString(),
    });
    var data = await response.json();
    if (!data.success) throw new Error(data.error || '验证失败');
    resultBox.classList.add(data.valid > 0 ? 'is-success' : 'is-error');
    resultBox.innerHTML = '<strong>验证完成：' + data.valid + '/' + data.total + ' 可用</strong>' +
      '<ul>' + data.results.map(function(item) {
        return '<li><span>' + escapeHtml(item.key) + '</span><b>' + (item.ok ? '可用' : '失败') + '</b>' + (item.error ? '<small>' + escapeHtml(item.error) + '</small>' : '') + '</li>';
      }).join('') + '</ul>';
  } catch (err) {
    resultBox.classList.add('is-error');
    resultBox.textContent = err.message;
  } finally {
    button.disabled = false;
  }
});
</script>
