<%- include('layout-open') %>
<div class="admin-page">
  <div class="page-header-bar">
    <h1>📊 控制面板</h1>
    <div class="header-actions">
      <% var hasProviders = typeof stats !== 'undefined' && stats.activeProviders > 0; %>
      <% if (hasProviders) { %>
        <form method="POST" action="/admin/cold-start" style="display:inline">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button type="submit" class="btn btn-primary" onclick="return confirm('将调用 AI 生成初始内容，确认？')">🚀 冷启动</button></form>
        <form method="POST" action="/admin/clear-content" style="display:inline">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button type="submit" class="btn btn-outline" onclick="return confirm('⚠️ 将清除所有文章、栏目，然后重新生成。确认？')">🗑️ 清除重新规划</button></form>
      <% } %>
    </div>
  </div>

  <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <% if (typeof outage !== 'undefined' && outage.active) { %>
  <div class="alert alert-warning">🚨 AI 提供商故障中 — 已持续 <%= outage.durationMinutes %> 分钟，每 3 分钟自动检测，恢复后自动补充内容。</div>
  <% } %>

  <% if (typeof workMode !== 'undefined' && workMode === 'rage') { %>
  <div class="alert" style="background:#3b1111;color:#fca5a5;border:1px solid #7f1d1d;">🔥 <strong>狂暴模式运行中</strong> — 档位 <%= (typeof rageStatus !== 'undefined' ? rageStatus.level : 3) %>，<%= (typeof rageStatus !== 'undefined' ? rageStatus.level : 3) %> 路并发持续生成内容 | <a href="/admin/settings" style="color:#fca5a5;text-decoration:underline">切换模式</a></div>
  <% } %>

  <% if (!hasProviders) { %>
  <div class="alert alert-warning">⚠️ 还没有可用的 AI 提供商！请前往 <a href="/admin/providers">AI 提供商</a> 添加。</div>
  <% } %>

  <div class="stats-grid">
    <div class="stat-card"><div class="stat-number"><%= stats.totalArticles %></div><div class="stat-label">已发布文章</div></div>
    <div class="stat-card"><div class="stat-number"><%= stats.totalPlanned %></div><div class="stat-label">待生成计划</div></div>
    <div class="stat-card"><div class="stat-number"><%= stats.totalCategories %></div><div class="stat-label">栏目数量</div></div>
    <div class="stat-card"><div class="stat-number"><%= stats.totalPageviews %></div><div class="stat-label">总浏览量</div></div>
    <div class="stat-card"><div class="stat-number"><%= stats.activeProviders %>/<%= stats.totalProviders %></div><div class="stat-label">AI 提供商</div></div>
  </div>

  <% if (typeof autonomyPlan !== 'undefined' && autonomyPlan.actions && autonomyPlan.actions.length > 0) { %>
  <div class="admin-panel autonomy-panel">
    <div class="panel-title-row">
      <h2>🧭 AI 自治决策队列</h2>
      <span class="panel-subtle"><%= autonomyPlan.generated_at || '' %></span>
    </div>
    <div class="autonomy-summary">
      <span>低质待重写 <strong><%= autonomyPlan.snapshot.qualityBlocked || 0 %></strong></span>
      <span>JSON失败 <strong><%= autonomyPlan.snapshot.jsonFailures || 0 %></strong></span>
      <span>异常Provider <strong><%= (autonomyPlan.snapshot.unhealthyProviders || []).length %></strong></span>
      <span>待写计划 <strong><%= autonomyPlan.snapshot.plannedCount || 0 %></strong></span>
    </div>
    <div class="autonomy-actions">
      <% autonomyPlan.actions.slice(0, 4).forEach(function(action) { %>
        <div class="autonomy-action">
          <span class="autonomy-priority"><%= action.priority %></span>
          <div>
            <strong><%= action.title %></strong>
            <p><%= action.reason %></p>
          </div>
          <code><%= action.taskType %></code>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <div class="admin-grid">
    <div class="admin-panel">
      <h2>📋 手动触发</h2>
      <div class="trigger-buttons">
        <form method="POST" action="/admin/trigger/news_collector">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">📡 采集资讯</button></form>
        <form method="POST" action="/admin/trigger/plan_structure">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">🧠 规划结构</button></form>
        <form method="POST" action="/admin/trigger/generate_content">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">✍️ 生成文章</button></form>
        <form method="POST" action="/admin/trigger/seo_update">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">🔍 SEO 更新</button></form>
        <form method="POST" action="/admin/trigger/seo_expert_audit">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">📊 SEO 审计</button></form>
        <form method="POST" action="/admin/trigger/analyze">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">📈 数据分析</button></form>
        <form method="POST" action="/admin/trigger/user_test">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button class="btn btn-outline">👤 用户测评</button></form>
      </div>
      <div style="margin-top:1rem">
        <form method="POST" action="/admin/toggle-loop" style="display:inline">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-lg <%= getConfig().ai_loop_enabled === '1' ? 'btn-success' : 'btn-warning' %>"><%= getConfig().ai_loop_enabled === '1' ? '🔄 自动循环：已开启' : '⏸ 自动循环：已关闭' %></button>
        </form>
      </div>
    </div>

    <div class="admin-panel">
      <h2>🤖 Agent 状态</h2>
      <% var roleNames = {site_manager:'🏢 站长',editor:'✏️ 编辑',reviewer:'🔍 审核',technician:'🔧 技术员',news_collector:'📡 新闻采集',writer:'✍️ 写手',planner:'🧠 规划师',seo_expert:'📊 SEO专家',analyzer:'📈 分析师',user_tester:'👤 测评员'}; %>
      <% roleNames = typeof agentRoleNames !== 'undefined' ? agentRoleNames : roleNames; %>
      <% var allRoles = typeof agentRoles !== 'undefined' ? agentRoles : ['site_manager','planner','news_collector','writer','reviewer','editor','seo_expert','user_tester','analyzer','technician']; %>
      <div class="agent-status-list">
        <% allRoles.forEach(function(role) { %>
        <% var s = agentStatuses[role] || { status: 'idle', dotClass: 'dot-gray', displayText: '空闲' }; %>
        <% var statusText = s.displayText || (s.status === 'working' ? (s.current_task || '工作中') : s.status === 'error' ? '❌ ' + (s.current_task || '错误') : '空闲'); %>
        <div class="agent-status-item">
          <span class="status-dot <%= s.dotClass || 'dot-gray' %>"></span>
          <span><%= roleNames[role] || role %></span>
          <span class="agent-task-text"><%= statusText %></span>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <div class="admin-panel">
    <h2>📜 最近 Agent 日志</h2>
    <table class="admin-table">
      <thead><tr><th>时间</th><th>角色</th><th>操作</th><th>AI 提供商</th><th>模型</th><th>状态</th><th>详情</th></tr></thead>
      <tbody>
        <% if (agentLogs.length > 0) { %>
          <% agentLogs.slice(0, 15).forEach(function(log) { %>
          <tr>
            <td class="td-time"><%= log.created_at || '' %></td>
            <td><span class="agent-badge"><%= roleNames[log.agent_role] || log.agent_role %></span></td>
            <td><%= log.action %></td>
            <td><%= log.ai_provider || '-' %></td>
            <td><code><%= log.ai_model || '-' %></code></td>
            <td><span class="status-badge status-<%= log.display_status_class || (log.status === 'success' ? 'published' : log.status === 'failed' ? 'archived' : 'planned') %>"><%= log.display_status || log.status %></span></td>
            <td class="td-detail"><%= (log.detail || '').slice(0, 60) %></td>
          </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="7" style="text-align:center">暂无日志</td></tr>
        <% } %>
      </tbody>
    </table>
    <% if (agentLogs.length > 15) { %><div style="text-align:right;margin-top:0.5rem"><a href="/admin/logs" class="btn btn-sm btn-outline">查看全部日志 →</a></div><% } %>
  </div>
</div>
<%- include('layout-close') %>
