<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>初始化 - AI 智能网站</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body login-page">
  <div class="login-container">
    <div class="login-card">
      <div class="login-header"><span class="login-icon">🚀</span><h1>初始化设置</h1><p>设置管理员密码以保护后台</p></div>
      <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form method="POST" action="/admin/setup">
        <div class="form-group"><label>设置密码</label><input type="password" name="password" required placeholder="至少4位"></div>
        <div class="form-group"><label>确认密码</label><input type="password" name="password2" required placeholder="再次输入密码"></div>
        <button type="submit" class="btn btn-primary btn-lg btn-block">🚀 开始使用</button>
      </form>
    </div>
  </div>
</body>
</html>
