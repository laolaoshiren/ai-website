      <div class="sidebar-header"><span class="sidebar-icon">🤖</span><span class="sidebar-title">AI 控制台</span></div>
      <nav class="sidebar-nav">
        <a href="/admin" class="sidebar-link<%= currentPath === '/admin' ? ' active' : '' %>">📊 控制面板</a>
