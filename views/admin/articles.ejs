<%- include('layout-open') %>
<div class="admin-page">
  <div class="page-header-bar">
    <h1>📝 文章管理</h1>
    <div class="header-actions">
      <a href="/admin/articles/new" class="btn btn-primary">➕ 新建文章</a>
    </div>
  </div>
  <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success">✅ 操作成功</div><% } %>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <!-- 搜索/筛选栏 -->
  <div class="admin-panel" style="padding:1rem 1.5rem">
    <form method="GET" action="/admin/articles" style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap">
      <input type="text" name="q" value="<%= q || '' %>" placeholder="🔍 搜索标题/摘要/关键词..." style="flex:1;min-width:200px;padding:0.45rem 0.9rem;border:1px solid var(--border);border-radius:var(--radius-full);background:var(--bg-sunken);color:var(--text-primary);font-size:var(--text-sm)">
      <select name="status" style="padding:0.45rem 0.7rem;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg-sunken);color:var(--text-primary);font-size:var(--text-sm)">
        <option value="">全部状态</option>
        <option value="published" <%= status === 'published' ? 'selected' : '' %>>已发布</option>
        <option value="planned" <%= status === 'planned' ? 'selected' : '' %>>计划中</option>
        <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>草稿</option>
      </select>
      <select name="sort" style="padding:0.45rem 0.7rem;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg-sunken);color:var(--text-primary);font-size:var(--text-sm)">
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>最新发布</option>
        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>最早发布</option>
        <option value="views" <%= sort === 'views' ? 'selected' : '' %>>阅读量排序</option>
      </select>
      <button type="submit" class="btn btn-primary btn-sm">筛选</button>
      <% if (q || status || sort !== 'newest') { %>
        <a href="/admin/articles" class="btn btn-outline btn-sm">清除</a>
      <% } %>
    </form>
    <% if (q || status) { %>
      <p class="text-muted" style="margin-top:0.5rem">
        <% if (q) { %>搜索 "<strong><%= q %></strong>" · <% } %>
        <% if (status) { %><%= status === 'published' ? '已发布' : status === 'planned' ? '计划中' : '草稿' %> · <% } %>
        共 <%= total %> 篇结果
      </p>
    <% } %>
  </div>

  <div class="admin-panel">
    <table class="admin-table">
      <thead><tr><th>标题</th><th>栏目</th><th>状态</th><th>浏览</th><th>创建时间</th><th>操作</th></tr></thead>
      <tbody>
        <% if (pages.length > 0) { %>
          <% var statusMap = {published:'已发布',planned:'计划中',draft:'草稿',archived:'已归档'}; %>
          <% pages.forEach(function(p) { %>
          <tr>
            <td class="td-title"><%= p.title %></td>
            <td><%= p.category_name || '-' %></td>
            <td><span class="status-badge status-<%= p.status %>"><%= statusMap[p.status] || p.status %></span></td>
            <td><%= p.view_count || 0 %></td>
            <td class="td-time"><%= (p.created_at || '').split(' ')[0] %></td>
            <td class="td-actions">
              <a href="/admin/articles/<%= p.id %>/edit" class="btn btn-sm btn-outline">✏️ 编辑</a>
              <% if (p.status === 'published') { %><a href="/article/<%= p.slug %>" target="_blank" class="btn btn-sm btn-outline">👁 查看</a><% } %>
              <% if (p.status === 'planned' || p.status === 'draft') { %>
                <form method="POST" action="/admin/articles/<%= p.id %>/status" style="display:inline">
                  <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="published"><button class="btn btn-sm btn-success">▶️ 发布</button></form>
              <% } %>
              <form method="POST" action="/admin/articles/<%= p.id %>/delete" style="display:inline">
                <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
                <button class="btn btn-sm btn-outline" onclick="return confirm('确认删除？')">🗑️</button></form>
            </td>
          </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6" style="text-align:center">暂无文章<% if (q) { %> — 未找到 "<%= q %>" 相关结果<% } %></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
  <div class="pagination">
    <% var qs = ''; if (q) qs += '&q=' + encodeURIComponent(q); if (status) qs += '&status=' + status; if (sort) qs += '&sort=' + sort; %>
    <% if (page > 1) { %><a href="?page=<%= page - 1 %><%= qs %>" class="btn btn-sm btn-outline">← 上一页</a><% } %>
    <span class="page-info">第 <%= page %> / <%= totalPages %> 页（共 <%= total %> 篇）</span>
    <% if (page < totalPages) { %><a href="?page=<%= page + 1 %><%= qs %>" class="btn btn-sm btn-outline">下一页 →</a><% } %>
  </div>
  <% } %>
</div>
<%- include('layout-close') %>
