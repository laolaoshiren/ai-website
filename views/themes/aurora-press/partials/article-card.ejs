<%
  var publishedAt = article.published_at ? String(article.published_at) : '';
  var cardImage = article.image_review_status === 'pass' ? (article.card_image || article.cover_thumbnail || article.cover_image) : '';
  var categoryName = article.category_name || '专题';
  var categorySlug = article.category_slug || '';
  var visualLabel = String(categoryName).slice(0, 2);
%>
<article class="ap-article-card">
  <a class="ap-card-media" href="/article/<%= article.slug %>" aria-label="<%= article.title %>">
    <% if (cardImage) { %>
      <img src="<%= cardImage %>" alt="<%= article.image_alt || article.title %>" loading="lazy" decoding="async">
    <% } else { %>
      <span class="ap-card-fallback">
        <span><%= visualLabel %></span>
        <small><%= categoryName %></small>
      </span>
    <% } %>
  </a>
  <div class="ap-card-body">
    <div class="ap-card-meta">
      <% if (categorySlug) { %>
        <a href="/category/<%= categorySlug %>"><%= categoryName %></a>
      <% } else { %>
        <span><%= categoryName %></span>
      <% } %>
      <% if (publishedAt) { %>
        <time datetime="<%= publishedAt.replace(' ', 'T') %>"><%= publishedAt %></time>
      <% } %>
    </div>
    <h3><a href="/article/<%= article.slug %>"><%= article.title %></a></h3>
    <% if (article.summary) { %>
      <p><%= String(article.summary).slice(0, 120) %></p>
    <% } %>
    <div class="ap-card-footer">
      <span><%= article.view_count || 0 %> 次阅读</span>
      <a href="/article/<%= article.slug %>">阅读全文</a>
    </div>
  </div>
</article>

