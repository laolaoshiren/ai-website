<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('partials/head') %>
</head>
<body class="sh-body">
  <%- include('partials/header') %>
  <main>
    <% var safeArticles = typeof articles !== 'undefined' && articles ? articles : []; %>
    <section class="sh-page-head">
      <div class="sh-container sh-page-head-inner">
        <div>
          <span class="sh-kicker">栏目简报</span>
          <h1><%= category.name %></h1>
          <p><%= category.description || '该栏目下的全部文章。' %></p>
        </div>
        <% if (pagination && pagination.totalItems > 0) { %>
          <div class="sh-page-count">
            <strong><%= pagination.totalItems %></strong>
            <span>篇文章</span>
          </div>
        <% } %>
      </div>
    </section>

    <section class="sh-section">
      <div class="sh-container">
        <% if (safeArticles.length > 0) { %>
          <div class="sh-card-grid">
            <% safeArticles.forEach(function(article) { %>
              <%- include('partials/article-card', { article: article }) %>
            <% }); %>
          </div>
          <%- include('partials/pagination', { pagination: pagination, itemLabel: '篇', ariaLabel: category.name + '分页' }) %>
        <% } else { %>
          <div class="sh-empty">
            <h2>这个栏目还在准备中</h2>
            <p>AI 会根据站点方向持续补充内容。</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
