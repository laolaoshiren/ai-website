<% if (pagination && pagination.totalPages > 1) { %>
  <% var paginationLabel = typeof itemLabel !== 'undefined' ? itemLabel : '条'; %>
  <% var paginationAria = typeof ariaLabel !== 'undefined' ? ariaLabel : '分页'; %>
  <nav class="sh-pagination" aria-label="<%= paginationAria %>">
    <% if (pagination.prevHref) { %>
      <a class="sh-page-step" href="<%= pagination.prevHref %>">上一页</a>
    <% } else { %>
      <span class="sh-page-step is-disabled">上一页</span>
    <% } %>

    <div class="sh-page-list">
      <% pagination.items.forEach(function(item) { %>
        <% if (item.type === 'ellipsis') { %>
          <span class="sh-page-ellipsis">...</span>
        <% } else if (item.isCurrent) { %>
          <span class="sh-page-link is-current" aria-current="page"><%= item.page %></span>
        <% } else { %>
          <a class="sh-page-link" href="<%= item.href %>"><%= item.page %></a>
        <% } %>
      <% }); %>
    </div>

    <% if (pagination.nextHref) { %>
      <a class="sh-page-step" href="<%= pagination.nextHref %>">下一页</a>
    <% } else { %>
      <span class="sh-page-step is-disabled">下一页</span>
    <% } %>

    <span class="sh-page-summary">第 <%= pagination.startItem %>-<%= pagination.endItem %> <%= paginationLabel %>，共 <%= pagination.totalItems %> <%= paginationLabel %></span>
  </nav>
<% } %>
