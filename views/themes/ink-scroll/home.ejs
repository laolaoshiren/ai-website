<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('partials/head') %>
</head>
<body class="ink-body">
  <%- include('partials/header') %>
  <main>
    <%
      var safeFeatured = typeof featured !== 'undefined' && featured ? featured : [];
      var safeLatest = typeof latest !== 'undefined' && latest ? latest : [];
      var lead = safeFeatured[0] || safeLatest[0] || null;
      var leadImage = lead && lead.image_review_status === 'pass' ? (lead.cover_image || lead.card_image || lead.cover_thumbnail) : '';
      var readingQueue = safeLatest.filter(function(item) { return !lead || item.slug !== lead.slug; }).slice(0, 6);
      var categoryList = typeof categories !== 'undefined' && categories ? categories : [];
    %>

    <section class="ink-manuscript">
      <div class="ink-container ink-manuscript-grid">
        <aside class="ink-manuscript-rail" aria-label="卷首目录">
          <span class="ink-kicker">长卷目录</span>
          <strong><%= siteTitle %></strong>
          <p><%= siteDescription || '把值得长期阅读的内容沉下来。' %></p>
          <% if (categoryList.length > 0) { %>
            <nav class="ink-rail-topics" aria-label="栏目">
              <% categoryList.slice(0, 8).forEach(function(cat, index) { %>
                <a href="/category/<%= cat.slug %>"><span><%= String(index + 1).padStart(2, '0') %></span><%= cat.name %></a>
              <% }); %>
            </nav>
          <% } %>
        </aside>

        <% if (lead) { %>
          <article class="ink-manuscript-lead">
            <div class="ink-lead-paper">
              <div class="ink-story-meta">
                <% if (lead.category_name) { %><a href="/category/<%= lead.category_slug %>"><%= lead.category_name %></a><% } %>
                <% if (lead.published_at) { %><time datetime="<%= String(lead.published_at).replace(' ', 'T') %>"><%= lead.published_at %></time><% } %>
              </div>
              <h1><a href="/article/<%= lead.slug %>"><%= lead.title %></a></h1>
              <% if (lead.summary) { %><p><%= lead.summary %></p><% } %>
              <a class="ink-primary-link" href="/article/<%= lead.slug %>">展开阅读</a>
            </div>
            <% if (leadImage) { %>
              <a class="ink-lead-stamp" href="/article/<%= lead.slug %>" aria-label="<%= lead.title %>">
                <img src="<%= leadImage %>" alt="<%= lead.image_alt || lead.title %>" loading="eager">
              </a>
            <% } else { %>
              <a class="ink-lead-stamp ink-lead-stamp-empty" href="/article/<%= lead.slug %>">
                <span><%= lead.category_name || '卷首' %></span>
              </a>
            <% } %>
          </article>
        <% } else { %>
          <div class="ink-empty ink-manuscript-empty">
            <h1><%= siteTitle %></h1>
            <p>系统完成规划后，这里会展示第一篇卷首文章。</p>
          </div>
        <% } %>
      </div>
    </section>

    <section class="ink-section ink-reading-section">
      <div class="ink-container ink-reading-layout">
        <div class="ink-section-heading">
          <span>阅读次序</span>
          <h2>最近更新</h2>
        </div>

        <% if (safeLatest.length > 0) { %>
          <div class="ink-card-list">
            <% safeLatest.forEach(function(article) { %>
              <%- include('partials/article-card', { article: article }) %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="ink-empty">
            <h2>AI 正在准备内容</h2>
            <p>配置完成后，系统会自动生成栏目和文章。</p>
          </div>
        <% } %>

        <aside class="ink-reading-aside" aria-label="继续阅读">
          <span class="ink-kicker">待读札记</span>
          <% if (readingQueue.length > 0) { %>
            <% readingQueue.forEach(function(item) { %>
              <a href="/article/<%= item.slug %>">
                <strong><%= item.title %></strong>
                <% if (item.published_at) { %><time><%= item.published_at %></time><% } %>
              </a>
            <% }); %>
          <% } else { %>
            <p>暂无更多文章。</p>
          <% } %>
        </aside>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
