<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('partials/head') %>
</head>
<body class="ink-body">
  <%- include('partials/header') %>
  <main>
    <%
      var safeFeatured = typeof featured !== 'undefined' && featured ? featured : [];
      var safeLatest = typeof latest !== 'undefined' && latest ? latest : [];
      var lead = safeFeatured[0] || safeLatest[0] || null;
      var sideStories = safeLatest.filter(function(item) { return !lead || item.slug !== lead.slug; }).slice(0, 5);
      var leadImage = lead && lead.image_review_status === 'pass' ? (lead.cover_image || lead.card_image || lead.cover_thumbnail) : '';
    %>

    <section class="ink-hero">
      <div class="ink-container ink-hero-grid">
        <div class="ink-hero-title">
          <span class="ink-kicker">今日卷首</span>
          <h1><%= siteTitle %></h1>
          <p><%= siteDescription || '把值得长期阅读的内容沉下来。' %></p>
        </div>

        <% if (lead) { %>
          <article class="ink-lead">
            <% if (leadImage) { %>
              <a class="ink-lead-image" href="/article/<%= lead.slug %>" aria-label="<%= lead.title %>">
                <img src="<%= leadImage %>" alt="<%= lead.image_alt || lead.title %>" loading="eager">
              </a>
            <% } %>
            <div class="ink-lead-copy">
              <div class="ink-story-meta">
                <% if (lead.category_name) { %><a href="/category/<%= lead.category_slug %>"><%= lead.category_name %></a><% } %>
                <% if (lead.published_at) { %><time datetime="<%= String(lead.published_at).replace(' ', 'T') %>"><%= lead.published_at %></time><% } %>
              </div>
              <h2><a href="/article/<%= lead.slug %>"><%= lead.title %></a></h2>
              <% if (lead.summary) { %><p><%= lead.summary %></p><% } %>
              <a class="ink-primary-link" href="/article/<%= lead.slug %>">细读此篇</a>
            </div>
          </article>
        <% } else { %>
          <div class="ink-empty">
            <h2>内容正在酝酿</h2>
            <p>系统完成规划后，这里会展示最新头条。</p>
          </div>
        <% } %>

        <aside class="ink-index" aria-label="最新文章">
          <span class="ink-kicker">新近目录</span>
          <% if (sideStories.length > 0) { %>
            <% sideStories.forEach(function(item, index) { %>
              <a href="/article/<%= item.slug %>">
                <span><%= String(index + 1).padStart(2, '0') %></span>
                <strong><%= item.title %></strong>
              </a>
            <% }); %>
          <% } else { %>
            <p>暂无更多文章。</p>
          <% } %>
        </aside>
      </div>
    </section>

    <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
      <section class="ink-category-ribbon">
        <div class="ink-container">
          <span>栏目</span>
          <% categories.slice(0, 9).forEach(function(cat) { %>
            <a href="/category/<%= cat.slug %>"><%= cat.name %></a>
          <% }); %>
        </div>
      </section>
    <% } %>

    <section class="ink-section">
      <div class="ink-container">
        <div class="ink-section-heading">
          <span>持续更新</span>
          <h2>最新文章</h2>
        </div>
        <% if (safeLatest.length > 0) { %>
          <div class="ink-card-list">
            <% safeLatest.forEach(function(article) { %>
              <%- include('partials/article-card', { article: article }) %>
            <% }); %>
          </div>
        <% } else { %>
          <div class="ink-empty">
            <h2>AI 正在准备内容</h2>
            <p>配置完成后，系统会自动生成栏目和文章。</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
