<header class="ink-site-header">
  <div class="ink-container ink-header-inner">
    <a class="ink-brand" href="/" aria-label="<%= siteTitle %> 首页">
      <span class="ink-brand-mark"><%= String(siteTitle || '站').slice(0, 1) %></span>
      <span>
        <strong><%= siteTitle %></strong>
        <small><%= siteDescription || '由 AI 持续维护的内容网站' %></small>
      </span>
    </a>

    <nav class="ink-nav" aria-label="主导航">
      <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">首页</a>
      <a href="/archive" class="<%= currentPath === '/archive' ? 'is-active' : '' %>">归档</a>
      <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
        <% categories.slice(0, 5).forEach(function(cat) { %>
          <a href="/category/<%= cat.slug %>" class="<%= currentPath === '/category/' + cat.slug ? 'is-active' : '' %>"><%= cat.name %></a>
        <% }); %>
      <% } %>
    </nav>

    <form class="ink-search" action="/search" method="get" role="search">
      <input type="search" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="搜索文章">
      <button type="submit">搜</button>
    </form>
  </div>
</header>
