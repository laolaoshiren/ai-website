<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('partials/head') %>
</head>
<body class="ink-body">
  <%- include('partials/header') %>
  <main>
    <%
      var safeArchive = typeof archive !== 'undefined' && archive ? archive : [];
      var safeTotalArticles = typeof totalArticles !== 'undefined' ? totalArticles : 0;
      var safeTotalMonths = typeof totalMonths !== 'undefined' ? totalMonths : 0;
    %>
    <section class="ink-page-head">
      <div class="ink-container ink-page-head-inner">
        <div>
          <span class="ink-kicker">归档</span>
          <h1>文章归档</h1>
          <p>共 <%= safeTotalArticles %> 篇文章，覆盖 <%= safeTotalMonths %> 个月。</p>
        </div>
        <% if (safeTotalArticles > 0) { %>
          <div class="ink-page-count">
            <strong><%= startArticle %>-<%= endArticle %></strong>
            <span>当前页</span>
          </div>
        <% } %>
      </div>
    </section>

    <section class="ink-section">
      <div class="ink-container">
        <% if (safeArchive.length > 0) { %>
          <div class="ink-archive">
            <% safeArchive.forEach(function(group) { %>
              <% var ym = group[0]; var items = group[1]; %>
              <section class="ink-archive-month">
                <h2><%= ym.slice(0, 4) %> 年 <%= parseInt(ym.slice(5, 7), 10) %> 月</h2>
                <div>
                  <% items.forEach(function(article) { %>
                    <a class="ink-archive-item" href="/article/<%= article.slug %>">
                      <time datetime="<%= String(article.published_at || '').replace(' ', 'T') %>"><%= article.published_at || '' %></time>
                      <strong><%= article.title %></strong>
                      <% if (article.category_name) { %><span><%= article.category_name %></span><% } %>
                    </a>
                  <% }); %>
                </div>
              </section>
            <% }); %>
          </div>
          <%- include('partials/pagination', { pagination: pagination, itemLabel: '篇', ariaLabel: '归档分页' }) %>
        <% } else { %>
          <div class="ink-empty">
            <h2>暂无已发布文章</h2>
            <p>文章发布后会自动进入归档。</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
