<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('partials/head') %>
</head>
<body class="nb-body">
  <%- include('partials/header') %>
  <%
    var coverImage = article.image_review_status === 'pass' ? article.cover_image : '';
    var publishedAt = article.published_at ? String(article.published_at) : '';
    var previous = typeof prevArticle !== 'undefined' ? prevArticle : null;
    var next = typeof nextArticle !== 'undefined' ? nextArticle : null;
    var related = typeof relatedArticles !== 'undefined' && relatedArticles ? relatedArticles : [];
    var topicItems = typeof topicPath !== 'undefined' && topicPath ? topicPath : [];
    var safeWordCount = typeof wordCount !== 'undefined' ? wordCount : 0;
    var safeReadTime = typeof readTime !== 'undefined' ? readTime : 1;
  %>
  <main>
    <article>
      <header class="nb-article-hero" <%- coverImage ? 'style="--nb-hero-image:url(' + coverImage + ')"' : '' %>>
        <div class="nb-hero-shade"></div>
        <div class="nb-container">
          <nav class="nb-crumbs" aria-label="位置">
            <a href="/">首页</a><span>/</span>
            <% if (article.category_name) { %><a href="/category/<%= article.category_slug %>"><%= article.category_name %></a><span>/</span><% } %>
            <span>正文</span>
          </nav>
          <div class="nb-article-title">
            <div class="nb-post-meta">
              <% if (article.category_name) { %><a href="/category/<%= article.category_slug %>"><%= article.category_name %></a><% } %>
              <% if (publishedAt) { %><time datetime="<%= publishedAt.replace(' ', 'T') %>"><%= publishedAt %></time><% } %>
            </div>
            <h1><%= article.title %></h1>
            <% if (article.summary) { %><p><%= article.summary %></p><% } %>
            <div class="nb-article-stats">
              <span><%= article.view_count || 0 %> 阅读</span>
              <span>约 <%= safeWordCount %> 字</span>
              <span><%= safeReadTime %> 分钟</span>
              <span>AI 生成</span>
            </div>
          </div>
        </div>
      </header>

      <div class="nb-container nb-article-layout">
        <div class="nb-prose">
          <%- article.content_html || '<p>内容加载中。</p>' %>
        </div>

        <aside class="nb-article-side">
          <section class="nb-widget">
            <div class="nb-widget-title"><span>文章信息</span></div>
            <div class="nb-info-list">
              <% if (article.category_name) { %><a href="/category/<%= article.category_slug %>">栏目：<%= article.category_name %></a><% } %>
              <% if (publishedAt) { %><span>时间：<%= publishedAt %></span><% } %>
              <span>阅读：<%= article.view_count || 0 %></span>
            </div>
          </section>
          <% if (article.seo_keywords) { %>
            <section class="nb-widget">
              <div class="nb-widget-title"><span>关键词</span></div>
              <div class="nb-category-cloud">
                <% article.seo_keywords.split(',').forEach(function(tag) { %>
                  <% var cleanTag = tag.trim(); if (cleanTag) { %>
                    <a href="/search?q=<%= encodeURIComponent(cleanTag) %>"><%= cleanTag %></a>
                  <% } %>
                <% }); %>
              </div>
            </section>
          <% } %>
        </aside>
      </div>
    </article>

    <% if (previous || next) { %>
      <nav class="nb-container nb-article-nav" aria-label="上下篇文章">
        <% if (previous) { %>
          <a href="/article/<%= previous.slug %>"><span>上一篇</span><strong><%= previous.title %></strong></a>
        <% } else { %><span></span><% } %>
        <% if (next) { %>
          <a href="/article/<%= next.slug %>"><span>下一篇</span><strong><%= next.title %></strong></a>
        <% } %>
      </nav>
    <% } %>

    <% if (related.length > 0) { %>
      <section class="nb-container nb-related-section">
        <div class="nb-section-title"><span>Related</span><h2>继续阅读</h2></div>
        <div class="nb-post-list">
          <% related.forEach(function(item) { %>
            <%- include('partials/article-card', { article: item }) %>
          <% }); %>
        </div>
      </section>
    <% } %>

    <% if (topicItems.length > 0) { %>
      <section class="nb-container nb-topic-path">
        <div class="nb-section-title"><span>Topic Path</span><h2>主题线索</h2></div>
        <ol>
          <% topicItems.forEach(function(item, index) { %>
            <li>
              <span><%= index + 1 %></span>
              <a href="/article/<%= item.slug %>"><%= item.title %></a>
              <% if (item.summary) { %><p><%= item.summary %></p><% } %>
            </li>
          <% }); %>
        </ol>
      </section>
    <% } %>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
