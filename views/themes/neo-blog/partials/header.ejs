<header class="nb-site-header" data-nb-header>
  <div class="nb-nav-shell">
    <a class="nb-brand" href="/" aria-label="<%= siteTitle %> 首页">
      <span class="nb-brand-mark">N</span>
      <span class="nb-brand-text">
        <strong><%= siteTitle %></strong>
        <small>AI BLOG</small>
      </span>
    </a>

    <nav class="nb-nav" aria-label="主导航" data-nb-nav>
      <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">首页</a>
      <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
        <% categories.slice(0, 5).forEach(function(cat) { %>
          <a href="/category/<%= cat.slug %>" class="<%= currentPath === '/category/' + cat.slug ? 'is-active' : '' %>"><%= cat.name %></a>
        <% }); %>
      <% } %>
      <a href="/archive" class="<%= currentPath === '/archive' ? 'is-active' : '' %>">归档</a>
    </nav>

    <div class="nb-nav-actions">
      <form class="nb-search" action="/search" method="get" role="search">
        <input type="search" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="搜索">
        <button type="submit" aria-label="搜索">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.4-3.4" /></svg>
        </button>
      </form>

      <button type="button" class="nb-icon-button" data-theme-mode-toggle onclick="toggleFrontendThemeMode()" aria-label="切换明暗模式">
        <span data-theme-mode-icon>☀</span>
      </button>

      <button type="button" class="nb-menu-button" data-nb-nav-toggle aria-label="展开导航" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
