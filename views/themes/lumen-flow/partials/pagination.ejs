<% if (pagination && pagination.totalPages > 1) { %>
  <% var lfItemLabel = typeof itemLabel !== 'undefined' ? itemLabel : '条'; %>
  <% var lfAria = typeof ariaLabel !== 'undefined' ? ariaLabel : '分页'; %>
  <nav class="lf-pagination" aria-label="<%= lfAria %>">
    <% if (pagination.prevHref) { %>
      <a class="lf-page lf-page-arrow" href="<%= pagination.prevHref %>" rel="prev">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        <span>上一页</span>
      </a>
    <% } else { %>
      <span class="lf-page lf-page-arrow is-disabled">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        <span>上一页</span>
      </span>
    <% } %>

    <div class="lf-page-list">
      <% pagination.items.forEach(function(item) { %>
        <% if (item.type === 'ellipsis') { %>
          <span class="lf-page-ellipsis">…</span>
        <% } else if (item.isCurrent) { %>
          <span class="lf-page is-current" aria-current="page"><%= item.page %></span>
        <% } else { %>
          <a class="lf-page" href="<%= item.href %>"><%= item.page %></a>
        <% } %>
      <% }); %>
    </div>

    <% if (pagination.nextHref) { %>
      <a class="lf-page lf-page-arrow" href="<%= pagination.nextHref %>" rel="next">
        <span>下一页</span>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6" /></svg>
      </a>
    <% } else { %>
      <span class="lf-page lf-page-arrow is-disabled">
        <span>下一页</span>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6" /></svg>
      </span>
    <% } %>

    <span class="lf-page-summary">
      第 <%= pagination.startItem %>-<%= pagination.endItem %> <%= lfItemLabel %>，共 <%= pagination.totalItems %> <%= lfItemLabel %>
    </span>
  </nav>
<% } %>
