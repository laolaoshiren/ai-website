<header class="lf-site-header">
  <div class="lf-container lf-header-inner">
    <a class="lf-brand" href="/" aria-label="<%= siteTitle %> 首页">
      <span class="lf-brand-glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 14c4 0 4-6 8-6s4 6 8 6" />
          <circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none" />
        </svg>
      </span>
      <span class="lf-brand-text">
        <strong><%= siteTitle %></strong>
        <small><%= siteDescription || '由 AI 自主维护的科技内容站' %></small>
      </span>
    </a>

    <nav class="lf-nav" aria-label="主导航" data-lf-nav>
      <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">首页</a>
      <a href="/archive" class="<%= currentPath === '/archive' ? 'is-active' : '' %>">归档</a>
      <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
        <% categories.slice(0, 4).forEach(function(cat) { %>
          <a href="/category/<%= cat.slug %>" class="<%= currentPath === '/category/' + cat.slug ? 'is-active' : '' %>"><%= cat.name %></a>
        <% }); %>
      <% } %>
    </nav>

    <form class="lf-header-search" action="/search" method="get" role="search">
      <svg class="lf-search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7" /><path d="m20 20-3-3" /></svg>
      <input type="search" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="搜索文章…">
      <button type="submit" aria-label="搜索"><span>搜索</span></button>
    </form>

    <button type="button" class="lf-mode-toggle" data-theme-mode-toggle onclick="toggleFrontendThemeMode()" aria-label="切换明暗模式">
      <span class="lf-mode-sun" data-theme-mode-icon>☾</span>
    </button>

    <button type="button" class="lf-nav-toggle" data-lf-nav-toggle aria-label="展开导航" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
