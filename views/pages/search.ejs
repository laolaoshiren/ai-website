<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('../partials/seo-head') %>
  <link rel="stylesheet" href="/css/style.css?v=7">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">

    <section class="page-header">
      <div class="container">
        <span class="page-kicker">Search</span>
        <h1 class="page-title">搜索<%= q ? ': ' + q : '' %></h1>
        <form action="/search" method="get" class="search-page-form">
          <input type="text" name="q" value="<%= q %>" placeholder="输入关键词搜索..." class="search-page-input">
          <button type="submit" class="btn btn-primary">搜索</button>
        </form>
        <% if (q) { %>
          <p class="page-desc">共找到 <strong><%= total %></strong> 篇相关文章</p>
        <% } %>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <% if (articles.length > 0) { %>
          <div class="articles-grid">
            <% articles.forEach(function(article) { %>
              <%- include('../partials/article-card', { article: article }) %>
            <% }); %>
          </div>
          <% if (totalPages > 1) { %>
            <div class="pagination">
              <% if (page > 1) { %>
                <a href="/search?q=<%= encodeURIComponent(q) %>&page=<%= page - 1 %>" class="btn btn-secondary">上一页</a>
              <% } %>
              <span class="page-current">第 <%= page %> / <%= totalPages %> 页</span>
              <% if (page < totalPages) { %>
                <a href="/search?q=<%= encodeURIComponent(q) %>&page=<%= page + 1 %>" class="btn btn-secondary">下一页</a>
              <% } %>
            </div>
          <% } %>
        <% } else if (q) { %>
          <div class="empty-state">
            <p>没有找到与 "<strong><%= q %></strong>" 相关的文章</p>
            <p>试试其他关键词吧</p>
          </div>
        <% } %>
      </div>
    </section>

  </main>
  <%- include('../partials/footer') %>
  <script src="/js/analytics.js"></script>
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry, i) {
        if (entry.isIntersecting) {
          setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(function(el) { observer.observe(el); });
  });
  </script>
</body>
</html>
