<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('../partials/seo-head') %>
  <link rel="stylesheet" href="/css/style.css?v=8">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">

    <section class="page-header">
      <div class="container">
        <span class="page-kicker">Topic</span>
        <h1 class="page-title"><%= category.name %></h1>
        <p class="page-desc">
          <% if (category.description) { %><%= category.description %><% } else { %>该栏目下的全部文章<% } %>
          <% if (pagination.totalItems > 0) { %>
            · 当前显示第 <%= pagination.startItem %>-<%= pagination.endItem %> 篇，共 <%= pagination.totalItems %> 篇
          <% } %>
        </p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <% if (articles.length > 0) { %>
          <div class="articles-grid">
            <% articles.forEach(function(article) { %>
              <%- include('../partials/article-card', { article: article }) %>
            <% }); %>
          </div>
          <%- include('../partials/pagination', { pagination: pagination, itemLabel: '篇', ariaLabel: category.name + '分页' }) %>
        <% } else { %>
          <div class="empty-state">
            <p>该栏目暂无文章</p>
            <p>AI 正在为这个栏目准备内容</p>
          </div>
        <% } %>
      </div>
    </section>

  </main>
  <%- include('../partials/footer') %>
  <script src="/js/analytics.js"></script>
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry, i) {
        if (entry.isIntersecting) {
          setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(function(el) { observer.observe(el); });
  });
  </script>
</body>
</html>
