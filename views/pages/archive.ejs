<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('../partials/seo-head') %>
  <link rel="stylesheet" href="/css/style.css?v=6">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">

    <section class="page-header">
      <div class="container">
        <span class="page-kicker">Archive</span>
        <h1 class="page-title">文章归档</h1>
        <p class="page-desc">所有已发布的文章按时间归档（共 <%= totalMonths %> 个月）</p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <% if (archive.length > 0) { %>
          <div class="archive-timeline">
            <% archive.forEach(function(group) { %>
              <% var ym = group[0]; var articles = group[1]; %>
              <div class="archive-group">
                <h2 class="archive-month">
                  <%= ym.slice(0, 4) %> 年 <%= parseInt(ym.slice(5, 7)) %> 月
                  <small class="archive-count">(<%= articles.length %> 篇)</small>
                </h2>
                <ul class="archive-list">
                  <% articles.forEach(function(a) { %>
                    <li class="archive-item">
                      <span class="archive-date"><%= (a.published_at || '').slice(8, 10) %>日</span>
                      <a href="/article/<%= a.slug %>" class="archive-link"><%= a.title %></a>
                      <% if (a.category_name) { %>
                        <span class="archive-category"><%= a.category_name %></span>
                      <% } %>
                    </li>
                  <% }); %>
                </ul>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p>暂无已发布的文章</p>
          </div>
        <% } %>

        <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %><a href="?page=<%= page - 1 %>" class="btn btn-sm btn-outline">← 上几月</a><% } %>
          <span class="page-info">第 <%= page %> / <%= totalPages %> 页</span>
          <% if (page < totalPages) { %><a href="?page=<%= page + 1 %>" class="btn btn-sm btn-outline">下几月 →</a><% } %>
        </div>
        <% } %>
      </div>
    </section>

  </main>
  <%- include('../partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
