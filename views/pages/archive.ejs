<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('../partials/seo-head') %>
  <link rel="stylesheet" href="/css/style.css?v=8">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">

    <section class="page-header">
      <div class="container">
        <span class="page-kicker">Archive</span>
        <h1 class="page-title">文章归档</h1>
        <p class="page-desc">
          共 <%= totalArticles %> 篇文章，覆盖 <%= totalMonths %> 个月
          <% if (totalArticles > 0) { %>
            ，当前显示第 <%= startArticle %>-<%= endArticle %> 篇
          <% } %>
        </p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <% if (archive.length > 0) { %>
          <div class="archive-timeline">
            <% archive.forEach(function(group) { %>
              <% var ym = group[0]; var articles = group[1]; %>
              <div class="archive-group">
                <h2 class="archive-month">
                  <%= ym.slice(0, 4) %> 年 <%= parseInt(ym.slice(5, 7), 10) %> 月
                  <small class="archive-count">(<%= articles.length %> 篇)</small>
                </h2>
                <ul class="archive-list">
                  <% articles.forEach(function(a) { %>
                    <li class="archive-item">
                      <span class="archive-date"><%= (a.published_at || '').slice(8, 10) %>日</span>
                      <a href="/article/<%= a.slug %>" class="archive-link"><%= a.title %></a>
                      <% if (a.category_name) { %>
                        <span class="archive-category"><%= a.category_name %></span>
                      <% } %>
                    </li>
                  <% }); %>
                </ul>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p>暂无已发布的文章</p>
          </div>
        <% } %>

        <%- include('../partials/pagination', { pagination: pagination, itemLabel: '篇', ariaLabel: '归档分页' }) %>
      </div>
    </section>

  </main>
  <%- include('../partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
