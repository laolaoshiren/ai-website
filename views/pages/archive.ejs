<!DOCTYPE html>
<html lang="<%= siteLanguage %>">
<head>
  <%- include('../partials/seo-head') %>
  <link rel="stylesheet" href="/css/style.css?v=7">
</head>
<body>
  <%- include('../partials/header') %>
  <main class="main-content">

    <section class="page-header">
      <div class="container">
        <span class="page-kicker">Archive</span>
        <h1 class="page-title">文章归档</h1>
        <p class="page-desc">
          共 <%= totalArticles %> 篇文章，覆盖 <%= totalMonths %> 个月
          <% if (totalArticles > 0) { %>
            ，当前显示第 <%= startArticle %>-<%= endArticle %> 篇
          <% } %>
        </p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <% if (archive.length > 0) { %>
          <div class="archive-timeline">
            <% archive.forEach(function(group) { %>
              <% var ym = group[0]; var articles = group[1]; %>
              <div class="archive-group">
                <h2 class="archive-month">
                  <%= ym.slice(0, 4) %> 年 <%= parseInt(ym.slice(5, 7), 10) %> 月
                  <small class="archive-count">(<%= articles.length %> 篇)</small>
                </h2>
                <ul class="archive-list">
                  <% articles.forEach(function(a) { %>
                    <li class="archive-item">
                      <span class="archive-date"><%= (a.published_at || '').slice(8, 10) %>日</span>
                      <a href="/article/<%= a.slug %>" class="archive-link"><%= a.title %></a>
                      <% if (a.category_name) { %>
                        <span class="archive-category"><%= a.category_name %></span>
                      <% } %>
                    </li>
                  <% }); %>
                </ul>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p>暂无已发布的文章</p>
          </div>
        <% } %>

        <% if (totalPages > 1) { %>
          <% var windowStart = Math.max(1, page - 2); %>
          <% var windowEnd = Math.min(totalPages, page + 2); %>
          <nav class="pagination archive-pagination" aria-label="归档分页">
            <% if (page > 1) { %>
              <a href="/archive?page=<%= page - 1 %>" class="pagination-button">上一页</a>
            <% } else { %>
              <span class="pagination-button is-disabled">上一页</span>
            <% } %>

            <div class="pagination-pages">
              <% if (windowStart > 1) { %>
                <a href="/archive?page=1" class="pagination-link">1</a>
                <% if (windowStart > 2) { %><span class="pagination-ellipsis">...</span><% } %>
              <% } %>

              <% for (var i = windowStart; i <= windowEnd; i++) { %>
                <% if (i === page) { %>
                  <span class="pagination-link is-current" aria-current="page"><%= i %></span>
                <% } else { %>
                  <a href="/archive?page=<%= i %>" class="pagination-link"><%= i %></a>
                <% } %>
              <% } %>

              <% if (windowEnd < totalPages) { %>
                <% if (windowEnd < totalPages - 1) { %><span class="pagination-ellipsis">...</span><% } %>
                <a href="/archive?page=<%= totalPages %>" class="pagination-link"><%= totalPages %></a>
              <% } %>
            </div>

            <% if (page < totalPages) { %>
              <a href="/archive?page=<%= page + 1 %>" class="pagination-button">下一页</a>
            <% } else { %>
              <span class="pagination-button is-disabled">下一页</span>
            <% } %>
          </nav>
        <% } %>
      </div>
    </section>

  </main>
  <%- include('../partials/footer') %>
  <script src="/js/analytics.js"></script>
</body>
</html>
