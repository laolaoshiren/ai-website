<% if (pagination && pagination.totalPages > 1) { %>
  <% var paginationLabel = typeof itemLabel !== 'undefined' ? itemLabel : '条'; %>
  <% var paginationAria = typeof ariaLabel !== 'undefined' ? ariaLabel : '分页'; %>
  <nav class="pagination numbered-pagination" aria-label="<%= paginationAria %>">
    <% if (pagination.prevHref) { %>
      <a href="<%= pagination.prevHref %>" class="pagination-button">上一页</a>
    <% } else { %>
      <span class="pagination-button is-disabled">上一页</span>
    <% } %>

    <div class="pagination-pages">
      <% pagination.items.forEach(function(item) { %>
        <% if (item.type === 'ellipsis') { %>
          <span class="pagination-ellipsis">...</span>
        <% } else if (item.isCurrent) { %>
          <span class="pagination-link is-current" aria-current="page"><%= item.page %></span>
        <% } else { %>
          <a href="<%= item.href %>" class="pagination-link"><%= item.page %></a>
        <% } %>
      <% }); %>
    </div>

    <% if (pagination.nextHref) { %>
      <a href="<%= pagination.nextHref %>" class="pagination-button">下一页</a>
    <% } else { %>
      <span class="pagination-button is-disabled">下一页</span>
    <% } %>

    <span class="pagination-summary">
      第 <%= pagination.startItem %>-<%= pagination.endItem %> <%= paginationLabel %> / 共 <%= pagination.totalItems %> <%= paginationLabel %>
    </span>
  </nav>
<% } %>
