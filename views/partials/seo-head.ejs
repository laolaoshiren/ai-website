<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> | <%= siteTitle %></title>
<meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : siteDescription %>">
<% if (typeof metaKeywords !== 'undefined' && metaKeywords) { %>
<meta name="keywords" content="<%= metaKeywords %>">
<% } %>
<meta property="og:title" content="<%= title %>">
<meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : siteDescription %>">
<meta property="og:type" content="<%= typeof article !== 'undefined' ? 'article' : 'website' %>">
<meta property="og:site_name" content="<%= siteTitle %>">
<link rel="canonical" href="<%= typeof currentPath !== 'undefined' ? currentPath : '' %>">
<% if (typeof article !== 'undefined' && article && article.schema_json) { %>
<script type="application/ld+json"><%- article.schema_json %></script>
<% } %>
