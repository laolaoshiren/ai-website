<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-info">
        <p class="footer-brand">🤖 <%= siteTitle %></p>
        <p class="footer-desc"><%= siteDescription %></p>
      </div>
      <div class="footer-links">
        <a href="/archive">文章归档</a>
        <a href="/rss.xml" target="_blank">RSS 订阅</a>
        <a href="/sitemap.xml" target="_blank">Sitemap</a>
        <a href="/admin">管理后台</a>
      </div>
      <div class="footer-ai">
        <p>✨ 本站内容由 AI 自动生成和维护</p>
        <p class="footer-copy">&copy; <%= new Date().getFullYear() %> <%= siteTitle %></p>
      </div>
    </div>
  </div>
</footer>
<button class="back-to-top" id="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="回到顶部">↑</button>
<script>
/* Theme toggle */
function toggleTheme(){
  var h=document.documentElement,c=h.getAttribute('data-theme'),n=c==='dark'?'light':'dark';
  h.setAttribute('data-theme',n);localStorage.setItem('theme',n);
  var i=document.querySelector('.theme-icon');if(i)i.textContent=n==='dark'?'☀️':'🌙';
}
/* Init theme icon */
(function(){var t=document.documentElement.getAttribute('data-theme'),i=document.querySelector('.theme-icon');if(i)i.textContent=t==='dark'?'☀️':'🌙';})();
/* Back to top */
window.addEventListener('scroll',function(){var b=document.getElementById('back-to-top');if(b)b.classList.toggle('visible',window.scrollY>300);});
/* Mobile nav */
function toggleNav(){var n=document.getElementById('main-nav'),o=document.getElementById('nav-overlay');if(!n||!o)return;n.classList.toggle('open');o.classList.toggle('active');document.body.style.overflow=o.classList.contains('active')?'hidden':'';}
</script>
