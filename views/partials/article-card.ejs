<article class="article-card fade-in">
  <% if (article.cover_image) { %>
    <div class="card-image">
      <a href="/article/<%= article.slug %>">
        <img src="<%= article.cover_image %>" alt="<%= article.title %>" loading="lazy">
      </a>
    </div>
  <% } %>
  <div class="card-content">
    <div class="card-meta">
      <% if (article.category_name) { %>
        <a href="/category/<%= article.category_slug %>" class="card-category"><%= article.category_name %></a>
      <% } %>
      <% if (article.published_at) { %>
        <%
          var pubDate = article.published_at.split(' ')[0];
          var parts = pubDate.split('-');
          var dateObj = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]));
          var now = new Date();
          var diffMs = now - dateObj;
          var diffDays = Math.floor(diffMs / 86400000);
          var timeLabel = '';
          if (diffDays <= 0) timeLabel = '今天';
          else if (diffDays === 1) timeLabel = '昨天';
          else if (diffDays < 7) timeLabel = diffDays + '天前';
          else if (diffDays < 30) timeLabel = Math.floor(diffDays / 7) + '周前';
          else timeLabel = pubDate;
        %>
        <time class="card-date" datetime="<%= pubDate %>"><%= timeLabel %></time>
      <% } %>
    </div>
    <h3 class="card-title">
      <a href="/article/<%= article.slug %>"><%= article.title %></a>
    </h3>
    <% if (article.summary) { %>
      <p class="card-summary"><%= article.summary %></p>
    <% } %>
    <div class="card-stats">
      <span class="stat-views">👁 <%= article.view_count || 0 %></span>
      <span class="stat-ai">🤖 AI 生成</span>
    </div>
  </div>
</article>
